<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="pos_self_order.selfOrderIndex" t-inherit-mode="extension">
        <xpath expr="//Router" position="inside">
            <t t-set-slot="vending-process" route="`/pos-self/${selfOrder.config.id}/vending-process`">
                <VendingProcessingScreen product="selfOrder.selectedVendingProduct"/>
            </t>
            <t t-set-slot="vending-success" route="`/pos-self/${selfOrder.config.id}/vending-success`">
                <VendingSuccessScreen product="selfOrder.selectedVendingProduct" reference="selfOrder.vendingReference"/>
            </t>
            <t t-set-slot="vending-payment-success" route="`/pos-self/${selfOrder.config.id}/vending-payment-success`">
                <VendingPaymentSuccessScreen product="selfOrder.selectedVendingProduct" reference="selfOrder.vendingReference"/>
            </t>
            <t t-set-slot="vending-error" route="`/pos-self/${selfOrder.config.id}/vending-error`">
                <VendingErrorScreen product="selfOrder.selectedVendingProduct" error="selfOrder.vendingErrorMessage" errorTitle="selfOrder.vendingErrorTitle"/>
            </t>
            <t t-set-slot="vending-out-of-service" route="`/pos-self/${selfOrder.config.id}/vending-out-of-service`">
                <VendingOutOfServiceScreen/>
            </t>
        </xpath>
        <xpath expr="//Router" position="before">
            <div t-if="showAdBanner" class="o_vending_ad_root">
                <video autoplay="autoplay" loop="loop" muted="muted" playsinline="playsinline" class="o_vending_ad_root_video">
                    <source src="/vending_kiosk_ui/static/src/video/panelSolar_infas.mp4" type="video/mp4"/>
                </video>
            </div>
        </xpath>
        <xpath expr="//div[@t-else='']" position="replace">
            <div t-else="" class="h-100 w-100">
                <t t-if="selfOrder.config.self_ordering_mode === 'vending'">
                    <VendingOutOfServiceScreen/>
                </t>
                <t t-else="">
                    <div class="h-100 w-100 d-flex align-items-center justify-content-center text-center">
                        Hey, looks like you forgot to create products or add them to pos_config. Please add them before using the Self Order
                    </div>
                </t>
            </div>
        </xpath>
    </t>
</templates>
